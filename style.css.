:root {
    --cream: #fffaf5;
    --brown: #3e2723;
    --gold: #c6a664;
    --text: #5d4037;
}

* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: 'Poppins', sans-serif; background: var(--cream); color: var(--brown); }
.container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

/* HERO */
.hero { height: 100vh; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.hero-video { position: absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; z-index:-1; }
.hero-overlay { background: rgba(0,0,0,0.5); width:100%; height:100%; display: flex; align-items: center; justify-content: center; }
.hero-content h1 { color: white; font-family: 'Playfair Display', serif; font-size: 3.5rem; text-align: center; max-width: 900px; line-height: 1.2; }
.btn-gold { margin-top: 30px; background: var(--gold); color: white; padding: 15px 40px; text-decoration: none; border-radius: 50px; font-weight: bold; }

/* ABOUT */
.about { padding: 100px 0; text-align: center; }
.about-paper { background: white; padding: 60px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); max-width: 900px; margin: 0 auto; }
.magic-quote { font-family: 'Dancing Script', cursive; font-size: 2rem; color: var(--gold); margin-top: 30px; }

/* SIGNATURES */
.signatures { background: #fdf3e7; padding: 100px 0; }
.title-serif { font-family: 'Playfair Display', serif; text-align: center; font-size: 3rem; margin-bottom: 50px; }
.signature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 30px; }
.sig-card { background: white; padding: 20px; border-radius: 15px; text-align: center; box-shadow: 0 5px 15px rgba(0,0,0,0.02); }
.sig-card img { width: 100%; height: 220px; object-fit: cover; border-radius: 10px; margin-bottom: 15px; }
.nrs { display: block; color: var(--gold); font-weight: bold; margin-bottom: 10px; }
.sig-vibe { font-style: italic; font-size: 0.9rem; color: var(--text); }

/* BLOGS */
.blogs { padding: 100px 0; }
.blog-entry { display: flex; align-items: center; gap: 50px; margin-bottom: 80px; }
.blog-entry.reverse { flex-direction: row-reverse; }
.blog-img-box { flex: 1; }
.blog-img-box img { width: 100%; height: 400px; object-fit: cover; border-radius: 20px; }
.blog-body { flex: 1.2; }
.captivating-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 900; margin-bottom: 20px; color: var(--brown); }

/* TEAM 4-3 GRID */
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 800px; margin: 0 auto; }
.member { text-align: center; background: white; padding: 30px 20px; border-radius: 15px; }
.avatar { width: 120px; height: 120px; background: #ddd; border-radius: 50%; margin: 0 auto 20px; border: 4px solid var(--gold); }
.vibe-text { font-family: 'Dancing Script', cursive; font-size: 1.2rem; color: var(--gold); margin-top: 15px; }

footer { background: var(--brown); color: white; text-align: center; padding: 50px; }
